# Server
PORT=3000

# JWT (use a long random string in production)
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d

# MySQL (match your local setup; DB must exist and schema applied)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=chirper

# AWS S3 (profile picture uploads)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=your-bucket-name

# Optional: set NODE_ENV=test for test runs (e.g. test DB)
# NODE_ENV=development
